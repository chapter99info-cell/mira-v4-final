{
  "entities": {
    "users": {
      "title": "User",
      "description": "Application user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "client"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "medicalAlerts": { "type": "string" },
        "painPoints": { "type": "array", "items": { "type": "string" } },
        "painLevel": { "type": "number" }
      },
      "required": ["uid", "email", "role"]
    },
    "bookings": {
      "title": "Booking",
      "description": "A massage session booking",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "serviceId": { "type": "string" },
        "serviceName": { "type": "string" },
        "therapistId": { "type": "string" },
        "therapistName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "duration": { "type": "number" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "deposit-paid", "fully-paid"] },
        "isWalkIn": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "needsHealthFundRebate": { "type": "boolean" }
      },
      "required": ["clientId", "serviceId", "date", "startTime", "status"]
    },
    "services": {
      "title": "Service",
      "description": "A massage service offered",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "fullPrice": { "type": "number" },
        "depositAmount": { "type": "number" },
        "duration": { "type": "number" },
        "image": { "type": "string" }
      },
      "required": ["name", "fullPrice", "depositAmount", "duration"]
    },
    "staff": {
      "title": "Staff",
      "description": "Therapist profile",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "avatar": { "type": "string" },
        "specialties": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["Working", "Off"] }
      },
      "required": ["name", "role", "status"]
    },
    "products": {
      "title": "Product",
      "description": "A product sold by the clinic (e.g., oils, balms)",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profiles"
    },
    "/bookings/{bookingId}": {
      "schema": "bookings",
      "description": "Session bookings"
    },
    "/services/{serviceId}": {
      "schema": "services",
      "description": "Available services"
    },
    "/staff/{staffId}": {
      "schema": "staff",
      "description": "Therapist profiles"
    },
    "/products/{productId}": {
      "schema": "products",
      "description": "Products for sale"
    }
  }
}
